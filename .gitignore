# ==============================================================
# SECURITY — never commit secrets
# ==============================================================
# Environment / secret files
.env
.env.*
!.env.example
*.env
secrets.*
*secret*
*secrets*
# Source code whose name legitimately contains "secret" is NOT a secret file.
# These negations must come AFTER the *secret*/*secrets* rules above.
!src/**/Secrets/
!src/**/Secrets/**
!tests/**/*Secret*.cs
!src/**/*Secret*.cs
!src/**/*Secret*.ts
!src/**/*Secret*.tsx
appsettings.*.json
!appsettings.json
!appsettings.Example.json

# Certificates and keys
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*.der
*.jks
*.keystore
id_rsa*
id_ed25519*

# ASP.NET DataProtection keyring — contains active cookie/token signing keys.
# Dev keys under src/Servicedesk.Api/keys; prod mounts /var/lib/servicedesk/keys.
keys/

# Cloud / service credentials
*credentials*
*.credentials
.azure/
.aws/
gcp-*.json
service-account*.json

