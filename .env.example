# Servicedesk environment variables — example
# Copy to .env (gitignored) and fill in real values for your local environment.
# NEVER commit the real .env file. NEVER put real secrets in this example file.

# PostgreSQL connection (dev). The .NET API reads this via configuration.
# Either of the two formats below works:
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=servicedesk_dev;Username=servicedesk_app;Password=CHANGE_ME_LOCAL_DEV
# SERVICEDESK_ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=servicedesk_dev;Username=servicedesk_app;Password=CHANGE_ME_LOCAL_DEV

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development
