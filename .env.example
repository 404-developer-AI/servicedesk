# Servicedesk environment variables — example
#
# This file is the template for PRODUCTION deployments. Copy it to `.env`
# (gitignored) on the Ubuntu host and fill in real values. docker-compose
# loads `.env` automatically and forwards the variables to the app container.
#
# For LOCAL DEVELOPMENT on Windows/macOS, do NOT use this file — secrets live
# in `dotnet user-secrets` and are read automatically in the Development
# environment. See README / ARCHITECTURE for the dev bootstrap commands.
#
# NEVER commit the real `.env`. NEVER put real secrets in this example file.

# ASP.NET Core environment. Production for real installs; dev machines rely
# on launchSettings.json instead.
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL connection string. The `SERVICEDESK_` prefix is stripped by the
# app's environment-variable configuration provider, so the effective key is
# `ConnectionStrings:Postgres`.
SERVICEDESK_ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=servicedesk;Username=servicedesk_app;Password=CHANGE_ME

# Audit log HMAC key — 32 random bytes, base64. Signs the audit hash chain.
# Generate with: openssl rand -base64 32
SERVICEDESK_Audit__HashKey=

# Data Protection master key — 32 random bytes, base64.
# Encrypts the ASP.NET keyring (cookies, antiforgery tokens) at rest in Postgres.
# Generate with: openssl rand -base64 32
SERVICEDESK_DataProtection__MasterKey=
